# =====================================================================
# AMANA — environment variables
# Copy to .env.local for development. NEVER commit .env.local.
# =====================================================================

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AMANA
NEXT_PUBLIC_DEFAULT_LOCALE=en

# === Mantle ===
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz
MANTLE_MAINNET_RPC=https://rpc.mantle.xyz
NEXT_PUBLIC_MANTLE_SEPOLIA_CHAIN_ID=5003
NEXT_PUBLIC_MANTLE_MAINNET_CHAIN_ID=5000

# === Privy embedded wallet ===
# Sign up at https://privy.io and get your App ID
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# === Anthropic Claude (agent reasoning) ===
ANTHROPIC_API_KEY=

# === Optional sponsor APIs (for bonus surface) ===
TENCENT_HUNYUAN_API_KEY=
NANSEN_API_KEY=
ELFA_API_KEY=
BYBIT_API_KEY=
BYBIT_API_SECRET=

# === Contract addresses (filled after deploy) ===
NEXT_PUBLIC_AMANA_VAULT_ADDRESS=
NEXT_PUBLIC_MOCK_USDC_ADDRESS=
NEXT_PUBLIC_MOCK_USDY_ADDRESS=
NEXT_PUBLIC_MOCK_MUSD_ADDRESS=
NEXT_PUBLIC_MOCK_AAVE_ADDRESS=
NEXT_PUBLIC_MOCK_MI4_ADDRESS=

# === ERC-8004 agent IDs (filled after registration on Mantle Mainnet) ===
NEXT_PUBLIC_ALLOCATOR_AGENT_ID=
NEXT_PUBLIC_RISK_AGENT_ID=
NEXT_PUBLIC_REPORTER_AGENT_ID=
NEXT_PUBLIC_ERC8004_REGISTRY_ADDRESS=

# === Foundry deploy ===
PRIVATE_KEY=
MANTLESCAN_API_KEY=
