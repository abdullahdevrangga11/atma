# ─────────────────────────────────────────────────────────────────────────────
# LLM provider — pick ONE (or set both and use LLM_PROVIDER to flip)
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic Claude Sonnet 4.5 (default if both keys are set)
# Pricing: $3/M input · $15/M output → ~$0.03 per orchestration
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini 2.5 Flash (~7× cheaper than Claude — use this for tight budgets)
# Pricing: $0.30/M input · $2.50/M output → ~$0.004 per orchestration
GEMINI_API_KEY=...

# Force a specific provider regardless of which keys are set.
# Values: anthropic | gemini
# LLM_PROVIDER=gemini

# Override the Gemini model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-pro

# ─────────────────────────────────────────────────────────────────────────────
# Mantle Sepolia (testnet) — used by Foundry deploy script + viem client
# ─────────────────────────────────────────────────────────────────────────────
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz
PRIVATE_KEY=0x...                  # deployer key, must hold MNT for gas
MANTLESCAN_API_KEY=...             # https://mantlescan.xyz for verification

# ─────────────────────────────────────────────────────────────────────────────
# Privy — embedded wallet for users
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID=...

# ─────────────────────────────────────────────────────────────────────────────
# Upstash Redis — optional, enables persistent cross-instance run history.
# Falls back to in-memory (single-instance) storage if unset. Set BOTH on Vercel
# so /reports, /network, /api/runs, and /api/status share one run log.
# ─────────────────────────────────────────────────────────────────────────────
# UPSTASH_REDIS_REST_URL=https://...upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# ─────────────────────────────────────────────────────────────────────────────
# Allow >6 week backtests (raises bill ceiling — disabled by default)
# ─────────────────────────────────────────────────────────────────────────────
# AMANA_ALLOW_LONG_BACKTEST=1

# ─────────────────────────────────────────────────────────────────────────────
# Filled in by the deploy script — DO NOT commit values
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CHAIN_ID=5003
NEXT_PUBLIC_AMANA_VAULT=
NEXT_PUBLIC_USDC=
NEXT_PUBLIC_USDY=
NEXT_PUBLIC_MUSD=
NEXT_PUBLIC_AAVE_POOL=
NEXT_PUBLIC_MI4=
